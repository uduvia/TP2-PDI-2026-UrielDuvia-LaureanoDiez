"""
 TUIA - Procesamiento de Imágenes I
    TP2 - Problema 1A: Segmentación del área de la cinta transportadora (ROI)
 
    Estrategia:
 La imagen tiene una estructura vertical clara:
    - Fondo superior / inferior oscuro
    - Borde metálico superior (muy brillante, ~200 de gris)
    - Línea de separación oscura (transición abrupta)
    - CINTA (ROI): fondo oscuro ~60-90 con pastillas encima  <-- lo que queremos
    - Línea de separación oscura (transición abrupta)
    - Borde metálico inferior (brillante, ~165 de gris)
    - Base / suelo
 
  El algoritmo detecta automáticamente los límites verticales buscando
  transiciones de luminosidad en el perfil de medias por fila.
  La cinta ocupa prácticamente todo el ancho de la imagen.
"""
 
import cv2
import numpy as np
 
# ─── 1. CARGA ──────────────────────────────────────────────────────────────────
IMAGE_PATH = '/mnt/user-data/uploads/pills.png'
img = cv2.imread("NUEVO_TP/TP2/TP2-PDI-2026-UrielDuvia-LaureanoDiez/imagenes/pills.png")
if img is None:
    raise FileNotFoundError(f"No se pudo cargar la imagen: {IMAGE_PATH}")
 
gray    = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)   # unidad: color
h, w    = gray.shape
print(f"[INFO] Imagen cargada: {w}x{h} px")
 
# ─── 2. PERFIL DE LUMINOSIDAD POR FILA ────────────────────────────────────────
# Media de intensidad por fila → vector 1D de shape (h,)
row_means = np.mean(gray, axis=1).astype(np.float32)
 
# Suavizamos el perfil con cv2.GaussianBlur aplicado al vector como imagen 1D
# (lo tratamos como imagen de 1 fila de h columnas, kernel de tamaño impar)
# unidad: Filtra_frecuencial / Transformacion y filtrado
profile_2d = row_means.reshape(1, h)                          # shape (1, h)
smoothed_2d = cv2.GaussianBlur(profile_2d, (1, 31), sigmaX=0) # kernel 1×31 sobre columnas
smooth = smoothed_2d.reshape(h)                                # volver a 1D
 
print(f"[INFO] Perfil de luminosidad calculado y suavizado ({h} filas)")
 
# ─── 3. DETECCIÓN AUTOMÁTICA DE LÍMITES VERTICALES ────────────────────────────
# Buscamos las dos transiciones principales:
#   a) Fin del borde metálico superior → inicio de la cinta (brillante → oscuro)
#   b) Fin de la cinta → inicio del borde metálico inferior (oscuro → brillante)
 
BRIGHT_THRESH = 120   # umbral para considerar "zona brillante" (borde metálico)
DARK_THRESH   = 50    # umbral para considerar "zona oscura" (línea de separación)
 
belt_top    = None
belt_bottom = None
 
# Buscamos de arriba hacia abajo: primera fila que cae bajo DARK_THRESH
# DESPUÉS de haber pasado por una zona brillante
found_bright_top = False
for r in range(h):
    if smooth[r] > BRIGHT_THRESH:
        found_bright_top = True
    if found_bright_top and smooth[r] < DARK_THRESH:
        # Avanzamos hasta que la cinta "empiece" (supere el mínimo oscuro)
        # La cinta propiamente dicha empieza cuando vuelve a subir de ~20
        for r2 in range(r, h):
            if smooth[r2] > 30:
                belt_top = r2
                break
        break
 
# Buscamos de abajo hacia arriba: primera fila (desde abajo) que cae bajo DARK_THRESH
# DESPUÉS de haber pasado por zona brillante (borde inferior)
found_bright_bot = False
for r in range(h - 1, -1, -1):
    if smooth[r] > BRIGHT_THRESH:
        found_bright_bot = True
    if found_bright_bot and smooth[r] < DARK_THRESH:
        # La cinta termina justo antes de esta transición oscura
        for r2 in range(r, -1, -1):
            if smooth[r2] > 30:
                belt_bottom = r2
                break
        break
 
# Fallback conservador si la detección falla
if belt_top is None or belt_bottom is None or belt_top >= belt_bottom:
    print("[WARN] Detección automática inconclusa, usando valores por defecto.")
    belt_top    = 195
    belt_bottom = 862
 
print(f"[INFO] Límite superior de la cinta: fila {belt_top}")
print(f"[INFO] Límite inferior de la cinta: fila {belt_bottom}")
print(f"[INFO] Alto de la ROI: {belt_bottom - belt_top} px")
print(f"[INFO] Ancho de la ROI: {w} px  (cinta ocupa todo el ancho)")
 
# ─── 4. EXTRACCIÓN DE LA ROI ──────────────────────────────────────────────────
roi = img[belt_top:belt_bottom, 0:w]
 
print(f"[INFO] ROI extraída: {roi.shape[1]}x{roi.shape[0]} px")

cv2.imshow('ROI - Cinta Transportadora', roi)
cv2.waitKey(0)
cv2.destroyAllWindows()

roi_gray = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)    # unidad: color
roi_hsv  = cv2.cvtColor(roi, cv2.COLOR_BGR2HSV)     # unidad: color
h_roi, w_roi = roi_gray.shape
print(f"[INFO] ROI extraída: {w_roi}x{h_roi} px  (filas {belt_top}-{belt_bottom})")
 
# ─── 3. PREPROCESAMIENTO: suavizado ───────────────────────────────────────────
# GaussianBlur reduce ruido de textura antes de umbralizar
# unidad: Filtra_frecuencial / Transformacion y filtrado
blurred = cv2.GaussianBlur(roi_gray, (5, 5), 0)
print("[INFO] Suavizado Gaussiano aplicado (kernel 5x5)")
 
# ─── 4. UMBRALIZACIÓN DE OTSU ─────────────────────────────────────────────────
# Otsu encuentra automáticamente el umbral óptimo por histograma bimodal
# fondo oscuro (~70-90) vs pastillas claras (~200-240)
# unidad: Segmentacion
ret, mask = cv2.threshold(blurred, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
print(f"[INFO] Umbral Otsu calculado: {ret:.0f}")
 
# ─── 5. MORFOLOGÍA: cierre y apertura ─────────────────────────────────────────
# CLOSE (dilatación→erosión): cierra huecos internos dentro de las pastillas
# OPEN  (erosión→dilatación): elimina ruido pequeño del fondo
# unidad: Morfologia
kernel_morph = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (5, 5))
mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, kernel_morph, iterations=2)
mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN,  kernel_morph, iterations=1)
print("[INFO] Operaciones morfológicas aplicadas (CLOSE x2, OPEN x1)")
 
# ─── 6. DETECCIÓN DE CONTORNOS ────────────────────────────────────────────────
# RETR_EXTERNAL: solo contornos exteriores (no anidados)
# CHAIN_APPROX_SIMPLE: comprime segmentos rectos, ahorra memoria
# unidad: Segmentacion
contours_raw, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
 
# Filtrar por área mínima para descartar ruido residual (<100 px²)
MIN_AREA = 100
contours = [c for c in contours_raw if cv2.contourArea(c) > MIN_AREA]
print(f"[INFO] Contornos detectados: {len(contours_raw)} totales → {len(contours)} después de filtro de área")
 
# ─── 7. CLASIFICACIÓN ─────────────────────────────────────────────────────────
# Para cada contorno extraemos:
#   - area          : cv2.contourArea
#   - aspect_ratio  : cv2.minAreaRect → lado_mayor / lado_menor
#   - blue_pixels   : cv2.inRange en HSV para detectar presencia de azul
#   - H, S, V medio : cv2.mean sobre los píxeles del contorno (máscara)
#
# Reglas de clasificación (en orden de prioridad):
#   1. blue_px > 25  AND area > 1000          → CAB (cápsula azul/blanca)
#   2. AR > 1.8      AND area > 2500 AND S>50 → CA  (cápsula amarilla)
#   3. AR < 1.3      AND S > 40               → RR  (redonda rosa)
#   4. AR < 1.3      AND S < 15               → RB  (redonda blanca)
#   5. resto                                  → ??
 
BLUE_LO = np.array([95,  60,  60])    # rango HSV para el color azul de las cápsulas
BLUE_HI = np.array([135, 255, 255])
blue_global = cv2.inRange(roi_hsv, BLUE_LO, BLUE_HI)   # unidad: Segmentacion (inRange)
 
pills = []   # lista de dicts con info de cada pastilla
 
for c in contours:
    area = cv2.contourArea(c)
    
    # Aspect ratio usando rectángulo mínimo rotado
    rect     = cv2.minAreaRect(c)
    rw, rh   = rect[1]
    ar       = max(rw, rh) / (min(rw, rh) + 1e-5)
    
    # Máscara individual del contorno para calcular stats de color
    cmask = np.zeros(roi_gray.shape, dtype=np.uint8)
    cv2.drawContours(cmask, [c], -1, 255, -1)
    
    # Color HSV promedio dentro del contorno
    mean_hsv = cv2.mean(roi_hsv, mask=cmask)
    H, S, V  = mean_hsv[0], mean_hsv[1], mean_hsv[2]
    
    # Contar píxeles azules dentro del contorno
    blue_px = cv2.countNonZero(cv2.bitwise_and(blue_global, blue_global, mask=cmask))
    
    # Bounding box para posición
    x, y, bw, bh = cv2.boundingRect(c)
    
    # Clasificación
    if blue_px > 25 and area > 1000:
        tipo = 'CAB'
    elif ar > 1.8 and area > 2500 and S > 50:
        tipo = 'CA'
    elif ar < 1.3 and S > 40:
        tipo = 'RR'
    elif ar < 1.3 and S < 15:
        tipo = 'RB'
    else:
        tipo = '??'
    
    pills.append({
        'contour' : c,
        'area'    : area,
        'ar'      : ar,
        'H': H, 'S': S, 'V': V,
        'blue_px' : blue_px,
        'tipo'    : tipo,
        'bbox'    : (x, y, bw, bh),
        'rect'    : rect,
    })
 
# ─── 8. ASIGNAR IDs Y CONTEO ──────────────────────────────────────────────────
# Ordenar por tipo para asignar IDs consecutivos por tipo
# y contar cuántas hay de cada uno
contadores = {}
for p in pills:
    t = p['tipo']
    contadores[t] = contadores.get(t, 0) + 1
    p['id'] = f"{t}{contadores[t]}"
 
# ─── 9. INFORME POR CONSOLA ───────────────────────────────────────────────────
print("\n" + "="*60)
print("  RESULTADOS - DETECCIÓN Y CLASIFICACIÓN DE PASTILLAS")
print("="*60)
print(f"\n  Total pastillas detectadas: {len(pills)}\n")
 
nombres = {
    'CAB': 'Cápsula Azul/Blanca',
    'CA' : 'Cápsula Amarilla   ',
    'RR' : 'Redonda Rosa       ',
    'RB' : 'Redonda Blanca     ',
    '??' : 'Sin clasificar     ',
}
for tipo, cant in sorted(contadores.items()):
    nombre = nombres.get(tipo, tipo)
    print(f"  {tipo}  {nombre}  → {cant:3d} unidades")
 
print("\n" + "-"*60)
print(f"  {'ID':<8} {'Tipo':<6} {'Area':>6} {'AR':>5} {'H':>5} {'S':>5} {'V':>5} {'BlPx':>6}")
print("-"*60)
for p in sorted(pills, key=lambda x: x['id']):
    print(f"  {p['id']:<8} {p['tipo']:<6} {p['area']:>6.0f} {p['ar']:>5.2f} "
          f"{p['H']:>5.1f} {p['S']:>5.1f} {p['V']:>5.1f} {p['blue_px']:>6}")
print("="*60)
 
# ─── 10. IMAGEN RESULTADO CON ETIQUETAS ───────────────────────────────────────
# Dibujamos sobre la imagen original (en coordenadas de la imagen completa)
# ajustando la posición de la ROI (belt_top offset en Y)
result = img.copy()
 
# Colores por tipo (BGR)
COLOR = {
    'CAB': (255, 100,   0),   # naranja azulado
    'CA' : (  0, 200, 255),   # amarillo
    'RR' : ( 60,  60, 255),   # rojo/rosa
    'RB' : (200, 200, 200),   # gris claro
    '??' : (  0, 255,   0),   # verde (no clasificado)
}
 
FONT       = cv2.FONT_HERSHEY_SIMPLEX
FONT_SCALE = 0.45
THICKNESS  = 1
 
for p in pills:
    c     = p['contour']
    color = COLOR.get(p['tipo'], (0, 255, 0))
    
    # Desplazar contorno al sistema de coordenadas de la imagen original
    c_offset = c + np.array([[[0, belt_top]]])
    
    # Dibujar contorno
    cv2.drawContours(result, [c_offset], -1, color, 2)
    
    # Bounding box y etiqueta
    x, y, bw, bh = p['bbox']
    y_orig = y + belt_top
    
    # Fondo de la etiqueta para legibilidad
    label   = p['id']
    (tw, th), _ = cv2.getTextSize(label, FONT, FONT_SCALE, THICKNESS)
    cv2.rectangle(result,
                  (x, y_orig - th - 4),
                  (x + tw + 2, y_orig),
                  color, -1)
    cv2.putText(result, label,
                (x + 1, y_orig - 3),
                FONT, FONT_SCALE, (0, 0, 0), THICKNESS)
 
# Leyenda en la esquina superior izquierda
leyenda_y = 20
cv2.rectangle(result, (5, 5), (210, 115), (30, 30, 30), -1)
for tipo, nombre in nombres.items():
    if tipo in contadores:
        color = COLOR.get(tipo, (255,255,255))
        cv2.rectangle(result, (10, leyenda_y - 10), (25, leyenda_y + 2), color, -1)
        cv2.putText(result,
                    f"{tipo}: {contadores.get(tipo,0)}  ({nombre.strip()})",
                    (30, leyenda_y),
                    FONT, 0.38, (255, 255, 255), 1)
        leyenda_y += 22
 
OUTPUT_PATH = 'resultado_pastillas.png'
cv2.imwrite(OUTPUT_PATH, result)
print(f"\n[OK] Imagen resultado guardada en: {OUTPUT_PATH}")
 
cv2.imshow('Resultado - Deteccion y Clasificacion', result)
cv2.waitKey(0)
cv2.destroyAllWindows()
